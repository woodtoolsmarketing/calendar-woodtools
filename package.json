{
  "name": "calendario-interactive",
  "version": "1.0.0",
  "description": "Calendario interactivo de tareas y programación de contenido para WoodTools",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "author": "WoodTools",
  "license": "MIT",
  "build": {
    "appId": "com.woodtools.calendario",
    "productName": "Calendario WoodTools",
    "files": [
      "main.js",
      "preload.js",
      "store.js",
      "recurrence.js",
      "credentials.js",
      "alert.html",
      "src/**/*",
      "integrations/**/*",
      "assets/**/*",
      "node_modules/fullcalendar/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Calendario WoodTools"
    }
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "fullcalendar": "^6.1.20"
  }
}
